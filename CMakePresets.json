{
  "version": 6,

  "configurePresets": [

    // ── Windows (MSVC 2022, x64) ─────────────────────────────────────────────
    {
      "name":        "windows-msvc-release",
      "displayName": "Windows MSVC Release (x64)",
      "generator":   "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir":   "${sourceDir}/build/windows-msvc-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "PSS_BUILD_TESTS":  "ON"
      }
    },
    {
      "name":        "windows-msvc-debug",
      "displayName": "Windows MSVC Debug (x64)",
      "generator":   "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir":   "${sourceDir}/build/windows-msvc-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "PSS_BUILD_TESTS":  "ON"
      }
    },

    // ── macOS (Ninja, release / debug) ───────────────────────────────────────
    {
      "name":        "macos-release",
      "displayName": "macOS Release (Ninja)",
      "generator":   "Ninja",
      "binaryDir":   "${sourceDir}/build/macos-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE":        "Release",
        "CMAKE_OSX_ARCHITECTURES": "arm64;x86_64",
        "PSS_BUILD_TESTS":         "ON"
      }
    },
    {
      "name":        "macos-debug",
      "displayName": "macOS Debug (Ninja)",
      "generator":   "Ninja",
      "binaryDir":   "${sourceDir}/build/macos-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE":        "Debug",
        "CMAKE_OSX_ARCHITECTURES": "arm64;x86_64",
        "PSS_BUILD_TESTS":         "ON"
      }
    },
    {
      "name":        "macos-local",
      "displayName": "macOS Local (native arch, Makefile)",
      "generator":   "Unix Makefiles",
      "binaryDir":   "${sourceDir}/build/macos-local",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "PSS_BUILD_TESTS":  "ON"
      }
    },

    // ── Linux (Ninja, release / debug) ───────────────────────────────────────
    {
      "name":        "linux-release",
      "displayName": "Linux Release (Ninja)",
      "generator":   "Ninja",
      "binaryDir":   "${sourceDir}/build/linux-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "PSS_BUILD_TESTS":  "ON"
      }
    },
    {
      "name":        "linux-debug",
      "displayName": "Linux Debug (Ninja)",
      "generator":   "Ninja",
      "binaryDir":   "${sourceDir}/build/linux-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "PSS_BUILD_TESTS":  "ON"
      }
    }
  ],

  "buildPresets": [
    { "name": "windows-msvc-release", "configurePreset": "windows-msvc-release", "configuration": "Release" },
    { "name": "windows-msvc-debug",   "configurePreset": "windows-msvc-debug",   "configuration": "Debug"   },
    { "name": "macos-release",        "configurePreset": "macos-release"  },
    { "name": "macos-debug",          "configurePreset": "macos-debug"    },
    { "name": "macos-local",          "configurePreset": "macos-local"    },
    { "name": "linux-release",        "configurePreset": "linux-release"  },
    { "name": "linux-debug",          "configurePreset": "linux-debug"    }
  ],

  "testPresets": [
    {
      "name":             "windows-msvc-release",
      "configurePreset":  "windows-msvc-release",
      "configuration":    "Release",
      "output":           { "outputOnFailure": true },
      "execution":        { "noTestsAction": "error", "stopOnFailure": false }
    },
    {
      "name":             "macos-release",
      "configurePreset":  "macos-release",
      "output":           { "outputOnFailure": true },
      "execution":        { "noTestsAction": "error", "stopOnFailure": false }
    },
    {
      "name":             "linux-release",
      "configurePreset":  "linux-release",
      "output":           { "outputOnFailure": true },
      "execution":        { "noTestsAction": "error", "stopOnFailure": false }
    },
    {
      "name":             "linux-debug",
      "configurePreset":  "linux-debug",
      "output":           { "outputOnFailure": true },
      "execution":        { "noTestsAction": "error", "stopOnFailure": false }
    }
  ]
}
